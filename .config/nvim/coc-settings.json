{
  "javascript.suggest.enabled": false,
  "coc.preferences.enableFloatHighlight": true,
  "coc.preferences.formatOnSaveFiletypes": ["ruby", "javascript", "python"],
  "coc.preferences.messageLevel": "more",
  "coc.preferences.useQuickfixForLocations": true,
  "suggest.floatEnable": false,
  "eslint.run": "onSave",
  "eslint.autoFixOnSave": true,
  "eslint.filetypes": ["javascript", "typescript", "typescriptreact"],
  "eslint.enable": true,
  "eslint.packageManager": "yarn",
  "javascript.validate.enable": false,
  "tsserver.ignoreLocalTsserver": false,
  "tsserver.trace.server": "verbose",
  "tsserver.enable": true,
  "tsserver.enableJavascript": false,
  "typescript.suggest.autoImports": true,
  "typescript.suggest.enabled": false,
  "typescript.suggestionActions.enabled": false,
  "typescript.suggest.completeFunctionCalls": true,
  "python.linting.enabled": false,
  "python.linting.pylintEnabled": true,
  "python.linting.pylintArgs": ["--rcfile=.pylintrc"],
  "python.linting.flake8Enabled": true,
  "python.formatting.provider": "none",
  "python.jediEnabled": false,
  "solargraph.checkGemVersion": false,
  "solargraph.diagnostics": true,
  "solargraph.formatting": false,
  "solargraph.useBundler": true,
  "solargraph.hover": true,
  "solargraph.definitions": true,
  "solargraph.logLevel": "debug",
  "languageserver": {
    "elmLS": {
      "command": "elm-language-server",
      "filetypes": ["elm"],
      "rootPatterns": ["elm.json"]
    },
    "cquery": {
      "command": "cquery",
      "args": ["--log-file=/tmp/cq.log"],
      "filetypes": ["c", "cpp"],
      "rootPatterns": ["compile_flags.txt", "compile_commands.json", ".git/", ".hg/"],
      "initializationOptions": {
        "cacheDirectory": "/tmp/cquery"
      }
    }
  }
}

